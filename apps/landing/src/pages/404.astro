---
import '../styles/global.css';
---
 
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 — Not Found</title>
  </head>
  <body class="min-h-screen">
    <main class="min-h-screen flex items-center justify-center px-6">
      <div class="text-center max-w-md">
        <p class="text-sm font-mono uppercase tracking-widest text-[var(--color-text-muted)] mb-4">404</p>
        <h1 class="text-3xl font-semibold mb-3">Page not found</h1>
        <p class="text-[var(--color-text-muted)] mb-8 leading-relaxed">
          That link doesn&apos;t lead anywhere, but the portfolio does.
        </p>
        <a href="/" class="inline-block text-sm font-mono text-[var(--color-accent)] hover:underline">
          &larr; back to portfolio
        </a>
      </div>
    </main>
  </body>
</html>
 