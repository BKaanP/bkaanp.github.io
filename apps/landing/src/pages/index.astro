---
import '../styles/global.css';

type Status = 'live' | 'building' | 'next';

const statusStyles: Record<Status, string> = {
  live: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/30',
  building: 'bg-amber-500/10 text-amber-400 border-amber-500/30',
  next: 'bg-red-500/10 text-red-400 border-red-500/30',
};

interface Project {
  title: string;
  description: string;
  tech: string[];
  href: string;
  status: Status;
  disabled?: boolean;
}

const projects: Project[] = [
  {
    title: 'Semantic Image Search',
    description: 'CLIP-powered image search running entirely in your browser. No server, no uploads.',
    tech: ['transformers.js', 'React', 'IndexedDB'],
    href: '/image-search/',
    status: 'live',
  },
  {
    title: 'Local-First RAG',
    description: 'Chat with your PDFs. Hybrid retrieval, query expansion, and streaming answers from Claude.',
    tech: ['RAG', 'BM25', 'transformers.js', 'pdf.js'],
    href: '/rag/',
    status: 'live',
  },
  {
    title: 'MCP Client',
    description: 'Browser-native Model Context Protocol client with a live agent loop and visible tool calls.',
    tech: ['MCP', 'Anthropic SDK', 'JSON-RPC'],
    href: '/mcp-client/',
    status: 'live',
  },
  {
    title: 'Managed CRM Stack',
    description: 'The MCP CRM server, lifted out of the browser and shipped as a real backend. Docker Compose for local dev, Kubernetes manifests, end-to-end tests.',
    tech: ['Docker', 'Kubernetes', 'Postgres', 'FastAPI', 'MCP'],
    href: '#',
    status: 'building',
    disabled: true,
  },
  {
    title: 'Novexa Global',
    description: 'Custom Next.js storefront for a business selling capsule homes. Multi-language with AI-generated product descriptions. Additionally AI focused workflow optimization',
    tech: ['Next.js', 'Postgres', 'Claude API', 'Vercel'],
    href: '#',
    status: 'next',
    disabled: true,
  },
];

const stats: Array<{ label: string; href: string }> = [
  { label: '3 apps live', href: '#' },
  {
    label: 'CI passing',
    href: 'https://github.com/bkaanp/bkaanp.github.io/actions',
  },
  { label: '100% typed', href: 'https://github.com/bkaanp/bkaanp.github.io' },
  {
    label: 'auto-deployed',
    href: 'https://github.com/bkaanp/bkaanp.github.io/blob/main/.github/workflows/deploy.yml',
  },
];

const siteUrl = 'https://bkaanp.github.io';
const title = 'Batuhan-Kaan Piskin — AI-integrated frontends';
const description = 'Portfolio of small, focused experiments at the intersection of AI and frontend engineering. Berlin-based.';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={siteUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <meta name="theme-color" content="#0a0a0a" />
  </head>
  <body class="min-h-screen">
    <main class="max-w-3xl mx-auto px-6 py-24">
      <header class="mb-20">
        <h1 class="text-4xl font-semibold tracking-tight mb-4">Batuhan-Kaan Piskin</h1>
        <p class="text-lg text-[var(--color-text-muted)] leading-relaxed">
          Frontend engineer working at the intersection of AI and product. Based in Berlin.
          Previously built an Azure-based RAG chatbot at Sparkassen Rating & Risikosysteme.
        </p>
      </header>

      <section class="mb-16">
        <h2 class="text-sm font-mono uppercase tracking-widest text-[var(--color-text-muted)] mb-6">Projects</h2>
        <ul class="space-y-4">
          {projects.map((p) => {
            const cardClass = 'block p-6 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] transition-colors';
            const activeClass = `${cardClass} hover:border-[var(--color-accent)]`;
            const nextClass = `${cardClass} opacity-70 cursor-default`;

            const inner = (
              <>
                <div class="flex items-baseline justify-between gap-4 mb-2">
                  <h3 class="text-lg font-medium">{p.title}</h3>
                  <span class={`text-xs font-mono px-2 py-0.5 rounded border ${statusStyles[p.status]}`}>
                    {p.status}
                  </span>
                </div>
                <p class="text-[var(--color-text-muted)] mb-4 leading-relaxed">{p.description}</p>
                <div class="flex flex-wrap gap-2">
                  {p.tech.map((t) => (
                    <span class="text-xs font-mono px-2 py-1 rounded bg-[var(--color-bg)] border border-[var(--color-border)]">{t}</span>
                  ))}
                </div>
              </>
            );

            return (
              <li>
                {p.disabled ? (
                  <div class={nextClass} aria-disabled="true">
                    {inner}
                  </div>
                ) : (
                  <a href={p.href} class={activeClass}>
                    {inner}
                  </a>
                )}
              </li>
            );
          })}
        </ul>
      </section>

      <section class="mb-16">
        <h2 class="text-sm font-mono uppercase tracking-widest text-[var(--color-text-muted)] mb-4">Engineering</h2>
        <ul class="flex flex-wrap gap-x-5 gap-y-2 text-xs font-mono text-[var(--color-text-muted)]">
          {stats.map((s) => (
            <li>
              <a href={s.href} class="hover:text-[var(--color-accent)] transition-colors">
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </section>

      <footer class="text-sm text-[var(--color-text-muted)]">
        <a href="https://github.com/bkaanp" class="hover:text-[var(--color-accent)] transition-colors">GitHub</a>
      </footer>
    </main>
  </body>
</html>